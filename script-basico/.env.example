# Copia este archivo como `.env` (o exporta las variables en tu shell)
# y reemplaza los valores con tus claves reales.

# Obligatoria: clave de Google AI Studio para Gemini.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# Opcional: clave de la API de NVD. Sin ella el rate limit es mucho menor.
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=tu_clave_de_nvd_aqui
